# Required. Local Postgres connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/timelend

# Optional. Use `require` on Railway/Render/Neon/Supabase if your provider needs SSL.
DATABASE_SSL=false

# Required. RPC used to read and resolve on-chain commitments.
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Required. Deployed TimeLend contract address.
CONTRACT_ADDRESS=0x5192258383C8cc29571e57697eAD535b96535bdE

# Required in real mode. This wallet must match the contract resolver address.
PRIVATE_KEY=0xYOUR_BACKEND_RESOLVER_PRIVATE_KEY

# Required for the real AI integration. Preferred variable name.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Legacy-compatible fallback variable name, supported by the code as well.
AIzaSyCyLWX6GjiskE9oB5ACJrrqlghV7hT7VHo=YOUR_GEMINI_API_KEY

# Optional. Defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Optional. Defaults to real. Use readonly to disable on-chain resolution writes.
MODE=real

# Optional. Defaults to 3000.
PORT=3000

# Optional. Comma-separated list of frontend origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:3001

# Optional. Defaults to 20000.
AI_TIMEOUT_MS=20000

# Optional. Defaults to 4194304 (4 MB).
MAX_PROOF_FILE_BYTES=4194304
