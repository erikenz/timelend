{
  "name": "@repo/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./TimeLendMVP": {
      "types": "./artifacts/src/TimeLendMVP.sol/TimeLendMVP.json",
      "default": "./artifacts/src/TimeLendMVP.sol/TimeLendMVP.json"
    },
    "./keys": "./keys.ts"
  },
  "files": [
    "artifacts"
  ],
  "scripts": {
