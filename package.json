{
  "name": "timelend",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "license": "UNLICENSED",
  "author": "",
  "scripts": {
    "build": "turbo run build",
    "bump-deps": "pnpm dlx npm-check-updates -w --format group -i -u",
    "bump-ui": "pnpp dlx shadcn@latest add --all --overwrite -c packages/design-system",
    "check": "ultracite check",
    "clean": "git clean -xdf node_modules",
    "dev": "turbo run dev",
    "fix": "ultracite fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:json": "pnpm dlx sort-package-json package.json packages/*/package.json apps/*/package.json",
    "preinstall": "pnpm dlx only-allow pnpm",
    "postinstall": "pnpm run format:json && pnpm run skills:install",
    "lint": "turbo run lint",
    "migrate": "cd packages/database && pnpm dlx prisma format && pnpm dlx prisma generate && pnpm dlx prisma migrate dev",
    "skills:install": "pnpm dlx skills experimental_install",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@repo/typescript-config": "workspace:*",
    "lint-staged": "^16.4.0",
    "turbo": "^2.8.20",
    "ultracite": "7.3.2"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18"
  }
}
